---
import '../styles/global.css';
import { ANALYTICS, SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.socialImage,
  imageAlt,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  tags = []
} = Astro.props;
const pageTitle = title === SITE.title ? title : `${title}｜${SITE.title}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(`${base}${image}`, Astro.site);
const socialImageAlt = imageAlt || (type === 'article' ? title : `${SITE.title}：${SITE.description}`);
const socialImageType = ({
  '.jpg': 'image/jpeg',
  '.jpeg': 'image/jpeg',
  '.png': 'image/png',
  '.svg': 'image/svg+xml',
  '.webp': 'image/webp'
} as Record<string, string>)[imageURL.pathname.match(/\.[a-z0-9]+$/i)?.[0]?.toLowerCase() ?? ''];
const currentPath = Astro.url.pathname;
const navItems = [
  { href: `${base}/`, label: '首页' },
  { href: `${base}/articles/`, label: '全部文章' },
  { href: `${base}/tutorials/`, label: '教程' },
  { href: `${base}/tags/`, label: '标签' },
  { href: `${base}/about/`, label: '关于' },
  { href: `${base}/rss.xml`, label: 'RSS' }
];
const analyticsEnabled = Boolean(ANALYTICS.umamiScript && ANALYTICS.umamiWebsiteId);
const websiteStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  description: SITE.description,
  url: new URL(`${base}/`, Astro.site).toString(),
  inLanguage: SITE.language,
  author: {
    '@type': 'Person',
    name: SITE.author
  }
};
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#276749" />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    {socialImageType && <meta property="og:image:type" content={socialImageType} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={`${base}/rss.xml`} />
    <link rel="alternate" type="application/atom+xml" title={`${SITE.title} Atom`} href={`${base}/atom.xml`} />
    <link rel="alternate" type="application/feed+json" title={`${SITE.title} JSON Feed`} href={`${base}/feed.json`} />
    <link rel="search" type="application/opensearchdescription+xml" title={`${SITE.title} Search`} href={`${base}/opensearch.xml`} />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
    {analyticsEnabled && (
      <script
        is:inline
        defer
        src={ANALYTICS.umamiScript}
        data-website-id={ANALYTICS.umamiWebsiteId}
      />
    )}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <header>
      <nav class="shell nav" aria-label="主导航">
        <a class="brand" href={`${base}/`}>{SITE.title}</a>
        <div class="nav-links">
          {navItems.map((item) => (
            <a
              href={item.href}
              aria-current={currentPath === item.href || (item.href !== `${base}/` && currentPath.startsWith(item.href)) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <div class="shell">© {new Date().getFullYear()} {SITE.author} · 由 Astro 和 GitHub Pages 驱动</div>
    </footer>
  </body>
</html>
