# 博客地址
SITE_URL=https://zhuchengxue.github.io

# 留空时自动寻找 Dropbox/公众号文章
WRITING_VAULT=

# 公众号自动草稿暂缓启用；以下配置仅为以后恢复接口预留
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_AUTHOR=学语思
WECHAT_DEFAULT_COVER=public/wechat-cover.svg

# 评论默认关闭。启用 GitHub Discussions + Giscus 后填写下面四项。
PUBLIC_GISCUS_REPO=zhuchengxue/zhuchengxue.github.io
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# 广告默认关闭。申请通过后再启用。
PUBLIC_ADS_ENABLED=false

# 可选：adsense 或 custom。adsense 用于 Google AdSense；custom 预留给国内广告代码。
PUBLIC_AD_PROVIDER=adsense

# Google AdSense 示例：ca-pub-xxxxxxxxxxxxxxxx
PUBLIC_ADSENSE_CLIENT=
PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=
PUBLIC_ADSENSE_SLOT_LIST_BOTTOM=
PUBLIC_ADSENSE_SLOT_TUTORIAL_TOP=
PUBLIC_ADSENSE_SLOT_TUTORIAL_BOTTOM=

# 国内广告或其它联盟可临时使用自定义 HTML；启用前请确认代码来源可信。
PUBLIC_AD_CUSTOM_HTML=
