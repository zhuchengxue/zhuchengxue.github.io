# 站点域名。绑定独立域名后改成 https://你的域名
SITE_URL=https://zhuchengxue.github.io

# GitHub Pages 自定义域名。留空则不生成 CNAME
CUSTOM_DOMAIN=

# 可选：Giscus 评论。不填则完全不加载评论脚本
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=

# 可选：Umami 访问统计。不填则完全不加载统计脚本
PUBLIC_UMAMI_SCRIPT=
PUBLIC_UMAMI_WEBSITE_ID=

# 可选：国内或备用静态镜像仓库。只在手动运行 npm run mirror 时使用
MIRROR_REPO=
MIRROR_BRANCH=pages
MIRROR_DOMAIN=
