---
import BaseLayout from './BaseLayout.astro';
import { getAllPosts } from '../lib/posts';
import { COMMENTS, SITE } from '../config';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    pubDate: string | Date;
    updatedDate?: string | Date;
    tags?: string[];
    cover?: string;
  };
  currentHref: string;
}

const { frontmatter, currentHref } = Astro.props;
const date = new Date(frontmatter.pubDate);
const updatedDate = frontmatter.updatedDate ? new Date(frontmatter.updatedDate) : undefined;
const allPosts = getAllPosts();
const currentIndex = allPosts.findIndex((post) => post.href === currentHref);
const currentPost = currentIndex >= 0 ? allPosts[currentIndex] : undefined;
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 ? allPosts[currentIndex + 1] : undefined;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = frontmatter.cover || `/og${currentHref}index.png`;
const commentsEnabled = Boolean(
  COMMENTS.giscusRepo
    && COMMENTS.giscusRepoId
    && COMMENTS.giscusCategory
    && COMMENTS.giscusCategoryId
);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: date.toISOString(),
  dateModified: (updatedDate ?? date).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author
  },
  image: new URL(`${base}${socialImage}`, Astro.site).toString(),
  keywords: frontmatter.tags?.join(', '),
  inLanguage: SITE.language,
  url: canonicalURL.toString(),
  mainEntityOfPage: canonicalURL.toString(),
  isPartOf: {
    '@type': 'Blog',
    name: SITE.title,
    url: new URL(`${base}/`, Astro.site).toString()
  }
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={socialImage}
  imageAlt={frontmatter.title}
  type="article"
  publishedTime={date.toISOString()}
  modifiedTime={(updatedDate ?? date).toISOString()}
  tags={frontmatter.tags}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>
  <article class="page">
    <header class="article-header">
      <div class="meta">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updatedDate && (
          <span>
            · 更新于 <time datetime={updatedDate.toISOString()}>
              {updatedDate.toLocaleDateString('zh-CN')}
            </time>
          </span>
        )}
        {currentPost && (
          <span>
            · {currentPost.wordCount.toLocaleString('zh-CN')} 字 · 约 {currentPost.readingMinutes} 分钟
          </span>
        )}
      </div>
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="summary">{frontmatter.description}</p>}
      {frontmatter.tags?.length && (
        <div class="tags">
          {frontmatter.tags.map((tag) => (
            <a class="tag" href={`${base}/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="article-body">
      <slot />
    </div>
    <footer class="article-footer">
      <nav class="post-navigation" aria-label="文章导航">
        <div>
          {newerPost && (
            <>
              <span>上一篇</span>
              <a href={`${base}${newerPost.href}`}>{newerPost.title}</a>
            </>
          )}
        </div>
        <div class="post-navigation-next">
          {olderPost && (
            <>
              <span>下一篇</span>
              <a href={`${base}${olderPost.href}`}>{olderPost.title}</a>
            </>
          )}
        </div>
      </nav>
      <a class="back-to-archive" href={`${base}/articles/`}>← 返回全部文章</a>
    </footer>
    {commentsEnabled && (
      <section class="comments" aria-label="评论">
        <h2>评论</h2>
        <script
          is:inline
          src="https://giscus.app/client.js"
          data-repo={COMMENTS.giscusRepo}
          data-repo-id={COMMENTS.giscusRepoId}
          data-category={COMMENTS.giscusCategory}
          data-category-id={COMMENTS.giscusCategoryId}
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="preferred_color_scheme"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async
        />
      </section>
    )}
  </article>
</BaseLayout>
