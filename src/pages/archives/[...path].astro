    { params: { path: '2017/12' } },
    { params: { path: '2018' } },
    { params: { path: '2018/01' } },
    { params: { path: '2018/02' } },
    { params: { path: '2018/03' } },
    { params: { path: '2018/04' } },
    { params: { path: '2020' } },
