    "status": "node scripts/status-report.mjs",
    "og:images": "node scripts/generate-og-images.mjs",
    "search:index": "node scripts/generate-search-index.mjs",
    "check:content": "node scripts/check-content.mjs",
    "check:build": "node scripts/check-built-site.mjs",
    "audit": "node scripts/audit-goal.mjs",
