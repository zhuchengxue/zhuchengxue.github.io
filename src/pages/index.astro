---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
import { getLegacyPosts, getNewPosts } from '../lib/posts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = getNewPosts();
const legacyCount = getLegacyPosts().length;
---

<BaseLayout>
  <section class="hero">
    <h1>{SITE.title}</h1>
    <p>{SITE.description}</p>
    <p class="hero-note">
      新文章与 {legacyCount} 篇旧文，共同构成一个持续生长的内容档案。
      <a href={`${base}/articles/`}>浏览全部文章 →</a>
    </p>
  </section>
  <section class="page" style="padding-top: 0">
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <div class="meta">
            {post.pubDate.toLocaleDateString('zh-CN')}
          </div>
          <h2><a href={`${base}${post.href}`}>{post.title}</a></h2>
          {post.description && <div class="summary">{post.description}</div>}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
