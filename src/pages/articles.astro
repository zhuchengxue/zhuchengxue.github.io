---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getAllPosts } from '../lib/posts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = getAllPosts();
---

<BaseLayout title="全部文章" description={`浏览和搜索学语思的 ${posts.length} 篇文章。`}>
  <section class="page archive-page">
    <header class="page-header">
      <p class="eyebrow">CONTENT ARCHIVE</p>
      <h1>全部文章</h1>
      <p class="summary">新旧文章汇于一处，共 {posts.length} 篇。</p>
    </header>

    <label class="search-box">
      <span class="sr-only">搜索文章</span>
      <input id="article-search" type="search" placeholder="搜索标题、摘要、标签或正文…" autocomplete="off" />
    </label>

    <p id="search-status" class="meta" aria-live="polite"></p>

    <ol class="archive-list" id="article-list">
      {posts.map((post) => (
        <li
          data-href={post.href}
          data-search={[
            post.title,
            post.description,
            ...post.tags
          ].filter(Boolean).join(' ').toLocaleLowerCase('zh-CN')}
        >
          <time datetime={post.pubDate.toISOString()}>
            {post.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })}
          </time>
          <div>
            <a href={`${base}${post.href}`}>{post.title}</a>
            {post.legacy && <span class="legacy-badge">旧文</span>}
            {post.description && <p>{post.description}</p>}
          </div>
        </li>
      ))}
    </ol>

    <AdSlot name="listBottom" label="文章列表广告" />

    <noscript><p class="meta">启用 JavaScript 后可在本页即时搜索；文章链接不受影响。</p></noscript>
  </section>
</BaseLayout>

<script>
  // @ts-nocheck
  const input = document.querySelector('#article-search');
  const items = Array.from(document.querySelectorAll('#article-list > li'));
  const status = document.querySelector('#search-status');
  const base = document.querySelector('base')?.href ?? window.location.origin;
  const indexURL = new URL('/search.json', base);

  let searchIndex;
  const normalize = (value) => value.toLocaleLowerCase('zh-CN');
  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') ?? '';
  const loadSearchIndex = async () => {
    if (searchIndex) return searchIndex;
    const response = await fetch(indexURL);
    searchIndex = await response.json();
    return searchIndex;
  };

  const runSearch = async () => {
    const query = normalize(input.value.trim());
    let visible = 0;
    const fullTextIndex = query ? await loadSearchIndex().catch(() => undefined) : undefined;
    const matches = new Set(
      fullTextIndex
        ?.filter((post) =>
          normalize([
            post.title,
            post.description,
            post.tags.join(' '),
            post.text
          ].filter(Boolean).join(' ')).includes(query)
        )
        .map((post) => post.href)
    );

    for (const item of items) {
      const itemMatches = !query || item.dataset.search?.includes(query) || matches.has(item.dataset.href ?? '');
      item.hidden = !itemMatches;
      if (itemMatches) visible++;
    }

    if (status) {
      status.textContent = query ? `找到 ${visible} 篇文章${fullTextIndex ? '（已包含正文搜索）' : ''}` : '';
    }
  };

  input?.addEventListener('input', runSearch);

  if (input && initialQuery) {
    input.value = initialQuery;
    runSearch();
  }
</script>
